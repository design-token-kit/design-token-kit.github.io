{
  "name": "DTK website",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.mjs",
    "check:import-case": "node scripts/check-import-case.mjs",
    "dev": "astro dev",
    "tokens:check": "dtokens check --scope validate --inform dtcg src/styles/tokens/tokens.json",
    "tokens:build": "dtokens convert --inform dtcg --outform css --out src/styles/tokens/tokens.css src/styles/tokens/tokens.json",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "build": "npm run lint:styles && astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@design-token-kit/core": "1.5.0",
    "astro": "7.0.7",
    "sass": "1.89.2"
  },
  "devDependencies": {
    "@design-token-kit/cli": "1.5.0",
    "@types/node": "22.20.1",
    "postcss-scss": "4.0.9",
    "stylelint": "16.23.1",
    "stylelint-config-standard-scss": "15.0.1",
    "stylelint-declaration-strict-value": "1.10.11",
    "typescript": "5.9.2"
  }
}
