---
import styles from '#/components/DocsPlayground/DocsPlayground.module.scss';
---

<section class={styles.docsPlayground} aria-labelledby="docs-playground-heading">
    <div class={styles.copy}>
        <p class={styles.eyebrow}>Learn and experiment</p>
        <h2 id="docs-playground-heading">Docs &amp; Playground</h2>
        <p>
            Explore the documentation, try examples in the playground, and get a
            DTCG token pipeline running in minutes.
        </p>
        <div class={styles.actions}>
            <a class={styles.primaryAction} href="#">Browse Docs</a>
            <a class={styles.secondaryAction} href="#">Open Playground</a>
        </div>
    </div>

    <div class={styles.console} aria-label="CLI command and CSS output examples">
        <div class={styles.sidebar} aria-label="Documentation sections">
            <span>Getting Started</span>
            <span>Installation</span>
            <span>Configuration</span>
            <span>Validation</span>
            <span>Conversion</span>
            <span>CLI Reference</span>
        </div>
        <div class={styles.commandPanel}>
            <h3>Playground</h3>
            <pre><code>{`$ npx dtokens convert \\
    --input tokens.json \\
    --format css \\
    --out tokens.css`}</code></pre>
            <p>Conversion complete · tokens.css · 3.2 KB</p>
        </div>
        <div class={styles.outputPanel}>
            <h3>CSS output</h3>
            <pre><code>{`:root {
    --color-primary-500: #0D766E;
    --color-primary-600: #0A5F59;
    --color-accent-500: #F59E0B;
    --radius-md: 8px;
}`}</code></pre>
        </div>
    </div>
</section>
