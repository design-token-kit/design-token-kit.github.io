---
import projectMark from '#/assets/logo/logotype-s.svg';
import styles from '#/components/Footer/Footer.module.scss';

interface FooterLink {
    label: string;
    href: string;
}

interface FooterGroup {
    title: string;
    links: FooterLink[];
}

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;

const footerGroups: FooterGroup[] = [
    {
        title: 'Product',
        links: [
            { label: 'Features', href: baseUrl },
            { label: 'CLI', href: `${baseUrl}docs/cli/validate/` },
            { label: 'API', href: `${baseUrl}docs/core/overview/` },
            { label: 'Changelog', href: '#' },
        ],
    },
    {
        title: 'Resources',
        links: [
            { label: 'Documentation', href: `${baseUrl}docs/` },
            { label: 'Playground', href: '#' },
            { label: 'Formats', href: `${baseUrl}docs/formats/dtcg/` },
            { label: 'Examples', href: `${baseUrl}docs/cli/convert/` },
        ],
    },
    {
        title: 'Community',
        links: [
            { label: 'GitHub', href: 'https://github.com/design-token-kit/design-token-kit' },
            { label: 'Discussions', href: '#' },
            { label: 'Contributing', href: '#' },
            { label: 'Code of Conduct', href: '#' },
        ],
    },
];
---

<footer class={styles.footer}>
    <div class={styles.inner}>
        <div class={styles.brandColumn}>
            <a class={styles.brand} href={baseUrl} aria-label="Design Token Kit home">
                <img src={projectMark.src} width="36" height="36" alt="" />
                <span>Design Token Kit</span>
            </a>
            <p>
                Open-source toolkit for DTCG design tokens. Built for validation,
                conversion, showcase generation, and analysis.
            </p>
        </div>

        <nav class={styles.groups} aria-label="Footer navigation">
            {footerGroups.map((footerGroup) => (
                <div>
                    <h2>{footerGroup.title}</h2>
                    <ul>
                        {footerGroup.links.map((footerLink) => (
                            <li><a href={footerLink.href}>{footerLink.label}</a></li>
                        ))}
                    </ul>
                </div>
            ))}
        </nav>
    </div>

    <p class={styles.copyright}>© {new Date().getFullYear()} Design Token Kit. Apache-2.0.</p>
</footer>
