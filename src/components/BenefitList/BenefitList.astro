---
import styles from '#/components/BenefitList/BenefitList.module.scss';
import type { ImageMetadata } from 'astro';

interface BenefitItem {
    title: string;
    icon: ImageMetadata;
}

interface Props {
    items: BenefitItem[];
}

const { items } = Astro.props;
---

<section class={styles.benefits} aria-label="Short benefits">
    <ul>
        {items.map((item) => (
            <li>
                <img src={item.icon.src} width="28" height="28" alt="" />
                <span>{item.title}</span>
            </li>
        ))}
    </ul>
</section>
