---
import projectMark from '#/assets/logo/logotype-s.svg';
import styles from '#/components/Header/Header.module.scss';

interface NavigationLink {
    label: string;
    href: string;
}

const navigationLinks: NavigationLink[] = [
    { label: 'Home', href: 'https://design-token-kit.github.io/' },
    { label: 'Docs', href: '#' },
    // { label: 'Playground', href: '#' },
    // { label: 'Showcase', href: '#' },
    { label: 'GitHub', href: 'https://github.com/design-token-kit/design-token-kit' },
];
---

<header class={styles.header}>
    <div class={styles.inner}>
        <a class={styles.brand} href="https://design-token-kit.github.io/" aria-label="Design Token Kit home">
            <img src={projectMark.src} width="40" height="37" alt=""/>
            <span>Design Token Kit</span>
        </a>

        <nav class={styles.navigation} aria-label="Primary navigation">
            {navigationLinks.map((navigationLink) => (
                <a href={navigationLink.href}>{navigationLink.label}</a>
            ))}
        </nav>

        <a class={styles.action} href="#">Get Started</a>
    </div>
</header>
