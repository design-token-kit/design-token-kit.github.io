---
import arrowRightIcon from '#/assets/icons/icon-arrow-right.svg';
import githubIcon from '#/assets/icons/icon-github.svg';
import projectMark from '#/assets/logo/logotype-l.svg';
import styles from '#/components/Hero/Hero.module.scss';

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
---

<section class={styles.hero} aria-labelledby="hero-heading">
    <div class={styles.content}>
        <p class={styles.eyebrow}>Open source</p>
        <h1 id="hero-heading">Design Token Kit</h1>
        <p class={styles.lead}>
            Validate, convert, showcase, and analyze DTCG design tokens with confidence.
        </p>
        <p class={styles.summary}>
           Give Your LLM a Design Language, not a screenshot.
        </p>
        <div class={styles.actions}>
            <a class={styles.primaryAction} href={`${baseUrl}docs/getting-started/`}>
                <span>Get Started</span>
                <img src={arrowRightIcon.src} width="24" height="24" alt="" />
            </a>
            <a
                class={styles.secondaryAction}
                href="https://github.com/design-token-kit/design-token-kit"
            >
                <span>View on GitHub</span>
                <img src={githubIcon.src} width="24" height="24" alt="" />
            </a>
        </div>
    </div>

    <div class={styles.visual} aria-hidden="true">
        <div class={styles.visualInner}>
            <span class={`${styles.rail} ${styles.railBack} ${styles.railOne}`}>
                <span class={`${styles.railItem} ${styles.itemTriangle} ${styles.itemTeal}`}></span>
            </span>
            <span class={`${styles.rail} ${styles.railBack} ${styles.railTwo}`}>
                <span class={`${styles.railItem} ${styles.itemDot} ${styles.itemAmber}`}></span>
            </span>
            <span class={`${styles.rail} ${styles.railBack} ${styles.railThree}`}>
                <span class={`${styles.railItem} ${styles.itemDiamond} ${styles.itemTeal}`}></span>
            </span>
            <span class={`${styles.rail} ${styles.railBack} ${styles.railFour}`}>
                <span class={`${styles.railItem} ${styles.itemCube} ${styles.itemTeal}`}></span>
            </span>

            <img
                src={projectMark.src}
                width={projectMark.width}
                height={projectMark.height}
                alt=""
            />

            <span class={`${styles.rail} ${styles.railFront} ${styles.railFive}`}>
                <span class={`${styles.railItem} ${styles.itemRing} ${styles.itemAmber}`}></span>
            </span>
            <span class={`${styles.rail} ${styles.railFront} ${styles.railSix}`}>
                <span class={`${styles.railItem} ${styles.itemDot} ${styles.itemAmber}`}></span>
            </span>
            <span class={`${styles.rail} ${styles.railFront} ${styles.railSeven}`}>
                <span class={`${styles.railItem} ${styles.itemCube} ${styles.itemTeal}`}></span>
            </span>
            <span class={`${styles.rail} ${styles.railFront} ${styles.railEight}`}>
                <span class={`${styles.railItem} ${styles.itemCube} ${styles.itemAmber}`}></span>
            </span>
            <span class={`${styles.rail} ${styles.railFront} ${styles.railNine}`}>
                <span class={`${styles.railItem} ${styles.itemSmallDot} ${styles.itemAmber}`}></span>
            </span>
        </div>
    </div>
</section>
