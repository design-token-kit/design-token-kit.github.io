---
import ArticleCard from '#/components/articles/ArticleCard.astro';
import styles from '#/components/sections/ArticlesSection.module.scss';
import { getLatestArticles } from '#/utils/articles';

const articles = await getLatestArticles(2);
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
---

{articles.length > 0 && (
    <section class={styles.articles} aria-labelledby="articles-heading">
        <div class={styles.header}>
            <div class={styles.copy}>
                <p class={styles.eyebrow}>ARTICLES</p>
                <h2 id="articles-heading">Articles</h2>
                <p class={styles.description}>
                    Guides, notes, and practical articles about design tokens and DTK.
                </p>
            </div>

            <a class={styles.allLink} href={`${baseUrl}articles/`}>View all articles →</a>
        </div>

        <div class={styles.grid}>
            {articles.map((article) => <ArticleCard article={article} />)}
        </div>
    </section>
)}
