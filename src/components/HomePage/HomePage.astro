---
import BenefitList from '#/components/BenefitList/BenefitList.astro';
import DocsPlayground from '#/components/DocsPlayground/DocsPlayground.astro';
import FeatureCard from '#/components/FeatureCard/FeatureCard.astro';
import Footer from '#/components/Footer/Footer.astro';
import Header from '#/components/Header/Header.astro';
import Hero from '#/components/Hero/Hero.astro';
import TechExample from '#/components/TechExample/TechExample.astro';
import benefitFormatAgnosticIcon from '#/assets/benefit-format-agnostic.svg';
import benefitProductionReadyIcon from '#/assets/benefit-production-ready.svg';
import benefitTypeSafeIcon from '#/assets/benefit-type-safe.svg';
import featureAnalyzeIcon from '#/assets/feature-analyze.svg';
import featureConvertIcon from '#/assets/feature-convert.svg';
import featureShowcaseIcon from '#/assets/feature-showcase.svg';
import featureValidateIcon from '#/assets/feature-validate.svg';
import styles from '#/components/HomePage/HomePage.module.scss';
import type { ImageMetadata } from 'astro';

interface BenefitItem {
    title: string;
    icon: ImageMetadata;
}

interface FeatureCardItem {
    title: string;
    description: string;
    icon: ImageMetadata;
    tone: 'teal' | 'amber';
}

const benefits: BenefitItem[] = [
    {
        title: 'Type-safe',
        icon: benefitTypeSafeIcon,
    },
    {
        title: 'Format agnostic',
        icon: benefitFormatAgnosticIcon,
    },
    {
        title: 'Production ready',
        icon: benefitProductionReadyIcon,
    },
];

const featureCards: FeatureCardItem[] = [
    {
        title: 'Validate',
        description: 'Catch issues early with a robust validation engine for structure, types, and naming.',
        icon: featureValidateIcon,
        tone: 'teal',
    },
    {
        title: 'Convert',
        description: 'Transform tokens between popular formats and frameworks in a single command.',
        icon: featureConvertIcon,
        tone: 'amber',
    },
    {
        title: 'Showcase',
        description: 'Generate beautiful, interactive documentation for your tokens automatically.',
        icon: featureShowcaseIcon,
        tone: 'teal',
    },
    {
        title: 'Analyze',
        description: 'Inspect token usage, detect duplicates, and measure coverage across a system.',
        icon: featureAnalyzeIcon,
        tone: 'amber',
    },
];
---

<Header/>

<main class={styles.homePage}>
    <Hero/>
    <BenefitList items={benefits}/>

    <section class={styles.features} aria-labelledby="features-heading">
        <div class={styles.sectionHeader}>
            <p class={styles.eyebrow}>Everything you need</p>
            <h2 id="features-heading">Built for modern design systems</h2>
        </div>
        <div class={styles.featureGrid}>
            {featureCards.map((featureCard) =>
                <FeatureCard {...featureCard}/>)}
        </div>
    </section>

    <TechExample/>
    <DocsPlayground/>
</main>

<Footer/>
