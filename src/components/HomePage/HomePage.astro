---
import BenefitList from '#/components/BenefitList/BenefitList.astro';
import DocsPlayground from '#/components/DocsPlayground/DocsPlayground.astro';
import FeatureCard from '#/components/FeatureCard/FeatureCard.astro';
import Footer from '#/components/Footer/Footer.astro';
import Header from '#/components/Header/Header.astro';
import Hero from '#/components/Hero/Hero.astro';
import TechExample from '#/components/TechExample/TechExample.astro';
import styles from '#/components/HomePage/HomePage.module.scss';
---

<Header/>

<main class={styles.homePage}>
    <Hero/>
    <BenefitList/>

    <section class={styles.features} aria-labelledby="features-heading">
        <div class={styles.sectionHeader}>
            <p class={styles.eyebrow}>Everything you need</p>
            <h2 id="features-heading">Built for modern design systems</h2>
        </div>
        <div class={styles.featureGrid}>
            <FeatureCard/>
        </div>
    </section>

    <TechExample/>
    <DocsPlayground/>
</main>

<Footer/>
