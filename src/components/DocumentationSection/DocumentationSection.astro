---
import featureConvertIcon from '#/assets/icons/feature-convert.svg';
import featureShowcaseIcon from '#/assets/icons/feature-showcase.svg';
import featureValidateIcon from '#/assets/icons/feature-validate.svg';
import docsPreview from '#/assets/docs-preview.png';
import styles from '#/components/DocumentationSection/DocumentationSection.module.scss';
import type { ImageMetadata } from 'astro';

interface BenefitItem {
    label: string;
    icon: ImageMetadata;
}

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;

const benefits: BenefitItem[] = [
    { label: 'CLI and Core API guides', icon: featureShowcaseIcon },
    { label: 'Features and configuration', icon: featureValidateIcon },
    { label: 'Formats and examples', icon: featureConvertIcon },
];
---

<section class={styles.documentation} aria-labelledby="documentation-heading">
    <div class={styles.sectionHeader}>
        <p class={styles.eyebrow}>DOCUMENTATION</p>
        <h2 id="documentation-heading">Docs written in Markdown</h2>
        <p>Browse project documentation, guides, and references from the Docs section.</p>
    </div>

    <div class={styles.documentationBlock}>
        <div class={styles.copy}>
            <p>
                Everything you need to work with Design Token Kit — from the first validation command to Core API
                integration. Explore features, supported formats, configuration options, and practical guides.
            </p>
            <a class={styles.action} href={`${baseUrl}docs/`}>Open Docs</a>
            <ul class={styles.benefits} aria-label="Documentation benefits">
                {benefits.map((benefit) => (
                    <li>
                        <span class={styles.benefitIcon} aria-hidden="true">
                            <img src={benefit.icon.src} width="16" height="16" alt=""/>
                        </span>
                        <span>{benefit.label}</span>
                    </li>
                ))}
            </ul>
        </div>

        <div class={styles.previewFrame}>
            <div class={styles.browserBar} aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <img
                src={docsPreview.src}
                width={docsPreview.width}
                height={docsPreview.height}
                alt="Documentation page preview with sidebar navigation and main Markdown content."
            />
        </div>
    </div>
</section>
