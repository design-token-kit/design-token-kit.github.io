---
import styles from '#/components/FeatureCard/FeatureCard.module.scss';
import type { ImageMetadata } from 'astro';

interface Props {
    title: string;
    description: string;
    icon: ImageMetadata;
    tone: 'teal' | 'amber';
}

const { title, description, icon, tone } = Astro.props;
const toneClass = tone === 'amber' ? styles.amber : styles.teal;
---

<article class={`${styles.card} ${toneClass}`}>
    <div class={styles.header}>
        <span class={styles.icon} aria-hidden="true">
            <img src={icon.src} width="32" height="32" alt="" />
        </span>
        <h3>{title}</h3>
    </div>
    <p>{description}</p>
    <a href="#">Learn more <span aria-hidden="true">→</span></a>
</article>
