---
import featureAnalyzeIcon from '#/assets/icons/feature-analyze.svg';
import featureConvertIcon from '#/assets/icons/feature-convert.svg';
import featureShowcaseIcon from '#/assets/icons/feature-showcase.svg';
import featureValidateIcon from '#/assets/icons/feature-validate.svg';
import styles from '#/components/FeatureCard/FeatureCard.module.scss';
import type { ImageMetadata } from 'astro';

interface FeatureCardItem {
    title: string;
    description: string;
    icon: ImageMetadata;
    href: string;
    tone: 'teal' | 'amber';
}

const baseUrl = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;

const items: FeatureCardItem[] = [
    {
        title: 'Validate',
        description: 'Catch issues early with a robust validation engine for structure, types, and naming.',
        icon: featureValidateIcon,
        href: `${baseUrl}docs/cli/validate/`,
        tone: 'teal',
    },
    {
        title: 'Convert',
        description: 'Transform tokens between popular formats and frameworks in a single command.',
        icon: featureConvertIcon,
        href: `${baseUrl}docs/cli/convert/`,
        tone: 'amber',
    },
    {
        title: 'Showcase',
        description: 'Generate beautiful, interactive documentation for your tokens automatically.',
        icon: featureShowcaseIcon,
        href: `${baseUrl}docs/cli/showcase/`,
        tone: 'teal',
    },
    {
        title: 'Analyze',
        description: 'Inspect token usage, detect duplicates, and measure coverage across a system.',
        icon: featureAnalyzeIcon,
        href: `${baseUrl}docs/cli/stats/`,
        tone: 'amber',
    },
];
---

{items.map((item) => {
    const toneClass = item.tone === 'amber' ? styles.amber : styles.teal;

    return (
        <article class={`${styles.card} ${toneClass}`}>
            <div class={styles.header}>
                <span class={styles.icon} aria-hidden="true">
                    <img src={item.icon.src} width="32" height="32" alt="" />
                </span>
                <h3>{item.title}</h3>
            </div>
            <p>{item.description}</p>
            <a href={item.href}>Learn more <span aria-hidden="true">→</span></a>
        </article>
    );
})}
