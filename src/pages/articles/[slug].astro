---
import Footer from '#/components/Footer/Footer.astro';
import Header from '#/components/Header/Header.astro';
import Layout from '#/layouts/Layout.astro';
import { render } from 'astro:content';
import styles from '#/pages/articles/article.module.scss';
import { getArticleSlug, getArticles } from '#/utils/articles';
import { formatEnglishDate } from '#/utils/dates';

export async function getStaticPaths() {
    const articles = await getArticles();

    return articles.map((article) => ({
        params: { slug: getArticleSlug(article) },
        props: { article },
    }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const baseUrl = import.meta.env.BASE_URL.endsWith('/')
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;
---

<Layout
    title={`${article.data.title} | Design Token Kit`}
    description={article.data.description}
>
    <Header />

    <main class={styles.page}>
        <article class={styles.article}>
            <a class={styles.backLink} href={`${baseUrl}articles/`}>← Back to all articles</a>

            <header class={styles.header}>
                <div class={styles.meta}>
                    {article.data.category && <span class={styles.badge}>{article.data.category}</span>}
                    <time datetime={article.data.date.toISOString()}>
                        {formatEnglishDate(article.data.date)}
                    </time>
                </div>

                <h1>{article.data.title}</h1>
                <p>{article.data.description}</p>
            </header>

            <div class={styles.content}>
                <Content />
            </div>
        </article>
    </main>

    <Footer />
</Layout>
